        "def load_quick_eval_results(file_path: Path) -> pd.DataFrame:\n",
        "    \"\"\"Load quick eval JSONL results into a DataFrame.\"\"\"\n",
        "    data = []\n",
        "    with open(file_path, 'r', encoding='utf-8') as f:\n",
        "        for line in f:\n",
        "            if line.strip():\n",
        "                record = json.loads(line.strip())\n",
        "                data.append(record)\n",
        "    \n",
        "    df = pd.DataFrame(data)\n",
        "    print(f\"✅ Loaded {len(df)} records from {file_path.name}\")\n",
        "    \n",
        "    # Extract OCEAN scores\n",
        "    for trait in TRAITS:\n",
        "        if 'ground_truth_ocean' in df.columns:\n",
        "            df[f'gt_{trait}'] = df['ground_truth_ocean'].apply(\n",
        "                lambda x: x.get(trait, 0.0) if isinstance(x, dict) else 0.0\n",
        "            )\n",
        "        if 'predicted_ocean' in df.columns:\n",
        "            df[f'pred_{trait}'] = df['predicted_ocean'].apply(\n",
        "                lambda x: x.get(trait, 0.0) if isinstance(x, dict) else np.nan\n",
        "            )\n",
        "    \n",
        "    # Add success flag\n",
        "    df['success'] = df['predicted_ocean'].notna()\n",
        "    \n",
        "    return df\n",
        "\n",
        "# Load the latest result\n",
        "if latest_file:\n",
        "    df = load_quick_eval_results(latest_file)\n",
