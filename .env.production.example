# Big5Loop – Production deployment env template
# Copy to .env and set real values. Never commit .env.
# Use a secret manager in production; inject at runtime.
# See docs/SECRETS-AND-CREDENTIALS.md

# ── Required for production ──
NEXTAUTH_SECRET=REQUIRED_generate_with_openssl_rand_base64_32
NEXTAUTH_URL=https://your-domain.com
POSTGRES_PASSWORD=REQUIRED_strong_password
DATABASE_URL=postgresql://big5loop:PASSWORD@db:5432/big5loop

# ── N8N (adjust host for your deployment) ──
N8N_WEBHOOK_URL=http://n8n:5678
NEXT_PUBLIC_N8N_WEBHOOK_URL=https://your-domain.com/n8n-or-proxy

# ── LLM (NVIDIA API or OpenAI-compatible) ──
NVIDIA_API_KEY=REQUIRED
NVIDIA_API_URL=https://integrate.api.nvidia.com/v1/chat/completions
NVIDIA_MODEL=google/gemma-3n-e4b-it
NVIDIA_EMBED_MODEL=nvidia/nv-embedqa-e5-v5

# ── Optional: audit and data ──
# AUDIT_DB_WRITE=true
# AUDIT_LOG_PATH=/tmp/audit.jsonl
# DATA_API_KEY=optional_for_export_delete_auth
