{
  "name": "big5loop",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "packages/contracts"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test:parse": "npm run test:parse --workspace=@big5loop/contracts",
    "test:runtime:phase1": "node scripts/phase1-runtime-check.js",
    "test:golden:phase1": "node scripts/phase1-golden-check.js",
    "test:intent:policy": "node scripts/policy-intent-check.js",
    "seed:policy": "node scripts/setup-rag-db.js",
    "chunk:policy": "node scripts/chunk-and-load-policy.js",
    "job:corpus-freshness": "node scripts/corpus-freshness-check.js",
    "job:source-recrawl": "node scripts/source-recrawl-reembed.js",
    "job:stale-citation": "node scripts/stale-citation-detector.js",
    "job:gateway-baseline-capture": "node scripts/gateway-baseline-capture.js",
    "job:gateway-canary-check": "node scripts/gateway-canary-check.js",
    "job:retrieval-smoke": "node scripts/retrieval-regression-smoke.js",
    "job:retrieval-regression": "node scripts/retrieval-regression-runner.js",
    "job:phase4-benchmark-expansion": "node scripts/retrieval-regression-runner.js scripts/fixtures/phase4-benchmark-expansion.json",
    "job:phase4-latency-benchmark": "node scripts/retrieval-regression-runner.js scripts/fixtures/phase4-latency-cases.json",
    "job:phase4-load-test": "node scripts/phase4-load-test.js"
  },
  "dependencies": {
    "pdf-parse": "^2.4.5",
    "pg": "^8.19.0"
  }
}
