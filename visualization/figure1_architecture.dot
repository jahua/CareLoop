digraph Big5LoopArchitecture {
  graph [
    bgcolor="white",
    pad="0.1",
    margin="0.02",
    rankdir="TB",
    nodesep="0.25",
    ranksep="0.35",
    splines="ortho",
    outputorder="edgesfirst",
    fontname="Helvetica Neue,Arial,Helvetica,sans-serif",
    concentrate="false"
  ];

  node [
    shape="plain",
    fontname="Helvetica Neue,Arial,Helvetica,sans-serif",
    fontsize="16",
    margin="0.08,0.05"
  ];

  edge [
    color="#7F8C8D",
    penwidth="1.4",
    arrowsize="0.9",
    arrowhead="vee",
    fontname="Helvetica Neue,Arial,Helvetica,sans-serif",
    fontsize="14"
  ];

  subgraph cluster_main {
    label="";
    color="#D8DEE2";
    penwidth="0.8";
    style="rounded";
    margin="12";

    /* ── Vertical flow: one node per rank ── */
    client [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#9AA8B0" BGCOLOR="#F8FAFA">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="22"><B>Client</B></FONT><BR/><FONT POINT-SIZE="22">(Next.js)</FONT></TD></TR>
      </TABLE>
    >];

    api_pre [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B8C97" BGCOLOR="#F7F9FA">
        <TR><TD WIDTH="220" BGCOLOR="#495A63"><FONT COLOR="white" POINT-SIZE="22"><B>API Pre-processing</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">Hybrid LLM router · Retrieval gate · Session isolation</FONT></TD></TR>
      </TABLE>
    >];

    input_norm [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#F8FAF8">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20">Input Normalization</FONT></TD></TR>
      </TABLE>
    >];

    context_extract [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#F8FAF8">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20">Context Extraction</FONT></TD></TR>
      </TABLE>
    >];

    merge_prev [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#F8FAF8">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20">Merge Previous State</FONT></TD></TR>
      </TABLE>
    >];

    /* ── Parallel branch: symmetric split ── */
    detect [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#E8F4EA">
        <TR><TD WIDTH="200" ALIGN="CENTER"><FONT POINT-SIZE="20"><B>OCEAN Detection</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">EMA + cache bypass</FONT></TD></TR>
      </TABLE>
    >];

    retrieval [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#E8F4EA">
        <TR><TD WIDTH="200" ALIGN="CENTER"><FONT POINT-SIZE="20"><B>Policy Retrieval</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">FTS / pgvector</FONT></TD></TR>
      </TABLE>
    >];

    regulation [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#E8F4EA">
        <TR><TD WIDTH="200" ALIGN="CENTER"><FONT POINT-SIZE="20"><B>Regulation</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">trait → directive</FONT></TD></TR>
      </TABLE>
    >];

    merge [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#DCE8E1">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20"><B>Merge</B></FONT></TD></TR>
      </TABLE>
    >];

    generate [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#F8FAF8">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20">Response Generation</FONT></TD></TR>
      </TABLE>
    >];

    verify [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#F8FAF8">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20">Grounding Verification</FONT></TD></TR>
      </TABLE>
    >];

    persist [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B9A8B" BGCOLOR="#DCE8E1">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="20"><B>Persistence &amp; Audit</B></FONT></TD></TR>
      </TABLE>
    >];

    api_post [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#7B8C97" BGCOLOR="#F7F9FA">
        <TR><TD WIDTH="220" BGCOLOR="#495A63"><FONT COLOR="white" POINT-SIZE="22"><B>API Post-processing</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">citation overlay · grounding check · audit</FONT></TD></TR>
      </TABLE>
    >];

    client_response [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#9AA8B0" BGCOLOR="#F8FAFA">
        <TR><TD WIDTH="220" ALIGN="CENTER"><FONT POINT-SIZE="22"><B>Client Response</B></FONT></TD></TR>
      </TABLE>
    >];

    /* ── Services: symmetric at bottom ── */
    llm [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#B3A892" BGCOLOR="#FBF9F4">
        <TR><TD WIDTH="200" BGCOLOR="#E7DECE"><FONT POINT-SIZE="20"><B>LLM Service</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">NVIDIA API · LLM 3.0</FONT></TD></TR>
      </TABLE>
    >];

    db [label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="10" COLOR="#B3A892" BGCOLOR="#FBF9F4">
        <TR><TD WIDTH="200" BGCOLOR="#E7DECE"><FONT POINT-SIZE="20"><B>Storage</B></FONT></TD></TR>
        <TR><TD ALIGN="CENTER"><FONT POINT-SIZE="22">PostgreSQL 16 + pgvector</FONT></TD></TR>
      </TABLE>
    >];

    /* Symmetric parallel pair */
    { rank=same; detect; retrieval; }
    { rank=same; llm; db; }

    /* ── Vertical main flow ── */
    client -> api_pre;
    api_pre -> input_norm;
    input_norm -> context_extract;
    context_extract -> merge_prev;

    merge_prev -> detect;
    merge_prev -> retrieval;

    detect -> regulation;
    regulation -> merge;
    retrieval -> merge;

    merge -> generate;
    generate -> verify;
    verify -> persist;
    persist -> api_post;
    api_post -> client_response;

    /* Service connections */
    detect -> llm [style="dashed", color="#95A5A6"];
    generate -> llm [style="dashed", color="#95A5A6"];
    persist -> db [style="dashed", color="#95A5A6"];
    retrieval -> db [style="dashed", color="#95A5A6"];
  }
}
