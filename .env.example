# Big5Loop Phase 0 – copy to .env and set values. Do not commit .env.
# See docs/SECRETS-AND-CREDENTIALS.md for how we store keys and credentials.

# Authentication (next-auth)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace_with_random_secret
NEXTAUTH_URL=http://localhost:3000

# PostgreSQL (for N8N and optional gateway)
POSTGRES_USER=big5loop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=big5loop

# N8N (server-side proxy in Next.js uses N8N_WEBHOOK_URL or NEXT_PUBLIC_*)
N8N_WEBHOOK_URL=http://localhost:5678
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678
# Full chat pipeline → N8N workflow id 940251a5-dd5b-4f5f-b024-513023536523 (five detector nodes); POST path:
N8N_DEFAULT_WORKFLOW_PATH=big5loop-pandora-eval-v4-five
# N8N basic auth (when N8N_BASIC_AUTH_ACTIVE=true in compose)
# N8N_BASIC_AUTH_USER=your-email@example.com
# N8N_BASIC_AUTH_PASSWORD=your-password


# Gemma 3 local inference (OpenAI-compatible server, e.g. vLLM/TGI)
NVIDIA_API_URL=http://host.docker.internal:8000/v1/chat/completions
NVIDIA_API_KEY=replace_with_nvidia_build_key
NVIDIA_MODEL=google/gemma-3-12b-it

# Aliyun / DashScope (for AutoSurvey: run_survey_aliyun.sh)
# Best model for survey: qwen-max (text gen + deep thinking)
ALIYUN_API_KEY=replace_with_aliyun_key
ALIYUN_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions
ALIYUN_MODEL=qwen-max

# Hybrid memory retrieval settings
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_EMBEDDING_MODEL=BAAI/bge-m3

# Phase 3: audit log (optional). If set, one JSONL line per turn is appended.
# Example: AUDIT_LOG_PATH=./logs/audit.jsonl
# AUDIT_LOG_PATH=

# Phase 3 P1-3: optional audit DB write. If AUDIT_DB_WRITE=true and AUDIT_DATABASE_URL (or DATABASE_URL) set, each turn is also written to audit_log table.
# AUDIT_DB_WRITE=false
# AUDIT_DATABASE_URL=postgresql://user:pass@host:5432/big5loop

# Phase 3 P1-11: data export/delete. GET /api/data/export and POST /api/data/delete use DATABASE_URL (or AUDIT_DATABASE_URL). If set, optional auth: DATA_API_KEY forces x-api-key or Authorization: Bearer <key>.
# DATABASE_URL=postgresql://big5loop:changeme@localhost:5432/big5loop
# DATA_API_KEY=

# Phase 3: feedback log (optional). If set, POST /api/feedback appends one JSONL line per submission.
# Example: FEEDBACK_LOG_PATH=./logs/feedback.jsonl
# FEEDBACK_LOG_PATH=

# P2 Gateway shadow: if set, POST /api/gateway/chat logs each request envelope (JSONL) for validation.
# GATEWAY_SHADOW_LOG=./logs/gateway-shadow.jsonl
# Optional when using gateway route: base URL of this app for internal forward to /api/chat (default: request origin).
# NEXT_PUBLIC_APP_URL=http://localhost:3003
# Optional: when set (true/1), frontend sends chat to /api/gateway/chat with routing_hints; gateway handles mode → workflow + model_tier.
# NEXT_PUBLIC_USE_GATEWAY=false
# Optional gateway auth: when set, POST /api/gateway/chat requires x-api-key or Authorization: Bearer.
# GATEWAY_API_KEY=
# Optional gateway rate limit: max requests per minute per user_id (or per IP if no user_id). 0 = disabled.
# GATEWAY_RATE_LIMIT_PER_MINUTE=60

# P2-9 Background jobs: if set, corpus-freshness-check.js appends JSONL telemetry here.
# BACKGROUND_JOB_LOG_PATH=./logs/background-jobs.jsonl
# Set CORPUS_FAIL_ON_EMPTY=0 to allow exit 0 when policy_chunks is empty (default: fail).
# CORPUS_FAIL_ON_EMPTY=1
# Stale citation detector tuning (optional):
# STALE_CITATION_MAX_URLS=100
# STALE_CITATION_TIMEOUT_MS=5000
# STALE_CITATION_FAIL_THRESHOLD=0.1
# STALE_CITATION_ALLOW_GET_FALLBACK=1
# Source recrawl / re-embedding job (safe default: dry-run enabled):
# SOURCE_RECRAWL_DRY_RUN=1
# SOURCE_RECRAWL_MAX_SOURCES=100
# SOURCE_CONFIG_PATH=./data/sources/cantonal/sources.config.json
# SOURCE_DOCUMENTS_PATH=./data/documents/cantonal/documents.json

# Gateway canary gate checker (P2-7):
# Baseline capture helper:
# BASELINE_BASE_URL=http://localhost:3003
# BASELINE_REQUESTS=30
# BASELINE_CONCURRENCY=3
# BASELINE_TIMEOUT_MS=20000
# BASELINE_ACCEPT_FAIL_RATE=0.2
# BASELINE_SESSION_PREFIX=00000000-0000-4000-8000-
# BASELINE_P95_MS=2000
# BASELINE_5XX_RATE=0.01
# CANARY_WINDOW_MINUTES=60
# MIN_REQUESTS=20
# MAX_5XX_ABS_INCREASE=0.01
# MAX_P95_INCREASE_MS=200
# MAX_429_RATE=0.05
# MAX_ERROR_ENVELOPE_RATE=0.05
# Optional citation-coverage check:
# BASELINE_AUDIT_LOG_PATH=./logs/audit-baseline.jsonl
# CANARY_AUDIT_LOG_PATH=./logs/audit-canary.jsonl
# MAX_POLICY_CITATION_DROP=0.05
