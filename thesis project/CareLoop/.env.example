# CareLoop Phase 0 – copy to .env and set values. Do not commit .env.
# See docs/SECRETS-AND-CREDENTIALS.md for how we store keys and credentials.

# PostgreSQL (for N8N and optional gateway)
POSTGRES_USER=careloop
POSTGRES_PASSWORD=changeme
POSTGRES_DB=careloop

# N8N (server-side proxy in Next.js uses N8N_WEBHOOK_URL or NEXT_PUBLIC_*)
N8N_WEBHOOK_URL=http://localhost:5678
NEXT_PUBLIC_N8N_WEBHOOK_URL=http://localhost:5678


# Gemma 3 local inference (OpenAI-compatible server, e.g. vLLM/TGI)
NVIDIA_API_URL=http://host.docker.internal:8000/v1/chat/completions
NVIDIA_API_KEY=replace_with_nvidia_build_key
NVIDIA_MODEL=google/gemma-3-12b-it

# Hybrid memory retrieval settings
MEMORY_RETRIEVAL_TOP_K=5
MEMORY_EMBEDDING_MODEL=BAAI/bge-m3
