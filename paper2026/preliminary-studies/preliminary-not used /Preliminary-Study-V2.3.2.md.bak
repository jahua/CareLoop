**C.2 N8N Workflow Node Configuration**

*Note: Complete N8N workflow JSON available in repository: `preliminary-studies/w9-Technical-Specifications/workflows/webhook-personality-pipeline.json`*

**Example: Personality Detection Node (JavaScript)**
```javascript
// File: n8n-nodes/detect-ocean.js
// Node: Zurich Model Detection (GPT-4 + EMA)
// Purpose: Continuous OCEAN inference with confidence-weighted EMA smoothing

const EMA_ALPHA = 0.3;  // Smoothing factor
const MIN_CONFIDENCE = 0.4;  // Minimum confidence for updates
const STABILIZATION_TURNS = 6;  // Turns required for stable designation

// Extract inputs from N8N workflow
const sessionId = $input.item.json.session_id;
const userMessage = $input.item.json.message;
const conversationHistory = $input.item.json.conversation_context || [];
const previousState = $input.item.json.previous_state || null;

// Build prompt for LLM
const detectionPrompt = `You are a Zurich Model personality assessor. Analyze the user's message and conversation history to infer OCEAN personality traits.

Conversation History:
${conversationHistory.map(turn => `User: ${turn.user}\nAssistant: ${turn.assistant}`).join('\n\n')}

Current User Message: "${userMessage}"

Return ONLY valid JSON in this exact format:
{
  "ocean": {"O": <-1.0 to 1.0>, "C": <-1.0 to 1.0>, "E": <-1.0 to 1.0>, "A": <-1.0 to 1.0>, "N": <-1.0 to 1.0>},
  "confidence": {"O": <0.0 to 1.0>, "C": <0.0 to 1.0>, "E": <0.0 to 1.0>, "A": <0.0 to 1.0>, "N": <0.0 to 1.0>},
  "reasoning": "Brief explanation of detected motivations"
}`;

// Call LLM API (OpenAI-compatible endpoint)
const llmResponse = await fetch('https://ai.juguang.chat/v1/chat/completions', {
  method: 'POST',
  headers: {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${process.env.JUGUANG_API_KEY}`
  },
  body: JSON.stringify({
    model: 'gemini-1.5-pro',
    messages: [
      {role: 'system', content: 'You are a personality assessment expert.'},
      {role: 'user', content: detectionPrompt}
    ],
    temperature: 0.1,
    max_tokens: 200
  })
});

const llmData = await llmResponse.json();
const rawDetection = JSON.parse(llmData.choices[0].message.content);

// Apply EMA smoothing if previous state exists
let smoothedOcean = {};
let smoothedConfidence = {};

const traits = ['O', 'C', 'E', 'A', 'N'];
for (const trait of traits) {
  const currentValue = rawDetection.ocean[trait];
  const currentConf = rawDetection.confidence[trait];
  
  if (previousState && currentConf >= MIN_CONFIDENCE) {
    // EMA: smoothed = α * current + (1 - α) * previous
    smoothedOcean[trait] = EMA_ALPHA * currentValue + (1 - EMA_ALPHA) * previousState.ocean[trait];
    smoothedConfidence[trait] = Math.max(currentConf, previousState.confidence[trait]);
  } else if (previousState) {
    // Low confidence: keep previous value
    smoothedOcean[trait] = previousState.ocean[trait];
    smoothedConfidence[trait] = previousState.confidence[trait];
  } else {
    // First turn: use raw detection
    smoothedOcean[trait] = currentValue;
    smoothedConfidence[trait] = currentConf;
  }
}

// Determine stability (requires 6+ consistent turns with low variance)
const turnCount = (previousState?.turn_count || 0) + 1;
const variance = previousState ? calculateVariance(smoothedOcean, previousState.ocean) : 1.0;
const stable = (turnCount >= STABILIZATION_TURNS && variance < 0.15);

// Helper function to calculate trait variance
function calculateVariance(current, previous) {
  const diffs = traits.map(t => Math.abs(current[t] - previous[t]));
  return diffs.reduce((a, b) => a + b, 0) / diffs.length;
}

// Return output for next N8N node
return {
  json: {
    session_id: sessionId,
    ocean: smoothedOcean,
    confidence: smoothedConfidence,
    stable: stable,
    turn_count: turnCount,
    variance: variance,
    reasoning: rawDetection.reasoning
  }
};
```

**Example: Regulation Node (Directive Mapping)**
```javascript
// File: n8n-nodes/enhanced-regulation.js
// Node: Enhanced Regulation
// Purpose: Map continuous OCEAN traits to behavioral directives

const DIRECTIVE_THRESHOLD = 0.2;  // Minimum |trait| value for activation

// Extract personality state
const ocean = $input.item.json.ocean;
const confidence = $input.item.json.confidence;
const stable = $input.item.json.stable;

// Initialize directive list
const directives = [];

// Openness directives (Arousal domain)
if (ocean.O > DIRECTIVE_THRESHOLD && confidence.O >= 0.4) {
  const intensity = ocean.O;
  if (intensity > 0.6) {
    directives.push("Strongly emphasize novel concepts and creative perspectives");
  } else {
    directives.push("Introduce some novel ideas and fresh approaches");
  }
} else if (ocean.O < -DIRECTIVE_THRESHOLD && confidence.O >= 0.4) {
  const intensity = Math.abs(ocean.O);
  if (intensity > 0.6) {
    directives.push("Use concrete, familiar examples; avoid abstract novelty");
  } else {
    directives.push("Prefer practical, proven approaches");
  }
}

// Conscientiousness directives (Structure domain)
if (ocean.C > DIRECTIVE_THRESHOLD && confidence.C >= 0.4) {
  const intensity = ocean.C;
  if (intensity > 0.6) {
    directives.push("Provide detailed structured plans with clear steps, timelines, and organization");
  } else {
    directives.push("Offer structured guidance with clear next steps");
  }
} else if (ocean.C < -DIRECTIVE_THRESHOLD && confidence.C >= 0.4) {
  const intensity = Math.abs(ocean.C);
  if (intensity > 0.6) {
    directives.push("Strongly emphasize flexibility; actively avoid rigid frameworks");
  } else {
    directives.push("Keep guidance flexible; minimize prescriptive structure");
  }
}

// Extraversion directives (Arousal domain)
if (ocean.E > DIRECTIVE_THRESHOLD && confidence.E >= 0.4) {
  directives.push("Use energetic, engaging tone; frame as collaborative");
} else if (ocean.E < -DIRECTIVE_THRESHOLD && confidence.E >= 0.4) {
  directives.push("Adopt calm, reflective tone; respect need for introspection");
}

// Agreeableness directives (Affiliation domain)
if (ocean.A > DIRECTIVE_THRESHOLD && confidence.A >= 0.4) {
  directives.push("Use warm, empathetic language; emphasize cooperation");
} else if (ocean.A < -DIRECTIVE_THRESHOLD && confidence.A >= 0.4) {
  directives.push("Maintain matter-of-fact, direct stance; respect autonomy");
}

// Neuroticism directives (Security domain)
if (ocean.N > DIRECTIVE_THRESHOLD && confidence.N >= 0.4) {
  const intensity = ocean.N;
  if (intensity > 0.6) {
    directives.push("Provide strong reassurance; acknowledge concerns; offer detailed coping strategies");
  } else {
    directives.push("Provide gentle reassurance and emotional validation");
  }
} else if (ocean.N < -DIRECTIVE_THRESHOLD && confidence.N >= 0.4) {
  directives.push("Match confident tone; focus on pragmatic solutions");
}

// Fallback if no directives triggered
if (directives.length === 0) {
  directives.push("Use balanced, neutral tone appropriate for general support");
}

return {
  json: {
    session_id: $input.item.json.session_id,
    directives: directives,
    ocean: ocean,
    confidence: confidence,
    stable: stable
  }
};
```

